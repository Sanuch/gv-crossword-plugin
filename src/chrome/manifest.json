{
  "manifest_version": 3,
  "name": "Crossword Solver",
  "version": "2.0",
  "description": "Finds crossword by ID and suggests words from configured services",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://godville.net/news", "https://godvillegame.com/news", "https://b.godville.net/news", "https://a.godville.net/news"],
      "js": ["contentScript.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["popup-modal.css", "popup-modal.js", "modal.js", "services.js"],
      "matches": ["https://godville.net/*", "https://godvillegame.com/*", "https://b.godville.net/*", "https://a.godville.net/*"]
    }
  ]
}